# === PRODUCTION ENVIRONMENT VARIABLES ===

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://ecoloop:CHANGE_ME@db:5432/ecoloop

# Authentication
JWT_SECRET=GENERATE_A_SECURE_64_CHAR_SECRET_HERE
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# AWS Services
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET=ecoloop-media-prod
SQS_GRADING_QUEUE=ecoloop-grading-queue
SQS_NOTIFICATION_QUEUE=ecoloop-notification-queue

# Email (SES)
SES_FROM_EMAIL=noreply@ecoloop.app

# Environment
ENVIRONMENT=production